# Environment Configuration for Waste Management Policy ML System

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Flask Server
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Database
DATABASE_URL=sqlite:///policy_analysis.db
DATABASE_ECHO=True

# Model Configuration
MODEL_PATH=./models/policy_analyzer.h5
CACHE_DIR=./.model_cache
LOG_DIR=./logs

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# React App
REACT_APP_ENV=development
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=30000

# ============================================================================
# DATA CONFIGURATION
# ============================================================================

# Data paths
DATA_PATH=./public_data_waste_fee.csv
OUTPUT_PATH=./The Output

# Data processing
DATA_FILTER_CUTOFF=0.1
DATA_FILTER_ORDER=4
DATA_ROLLING_WINDOW=5
DATA_VARIANCE_THRESHOLD=0.1

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

# Training parameters
MODEL_EPOCHS=50
MODEL_BATCH_SIZE=32
MODEL_TEST_SIZE=0.2
MODEL_RANDOM_STATE=42
MODEL_LEARNING_RATE=0.001

# ============================================================================
# POLICY ANALYSIS PARAMETERS
# ============================================================================

# Policy thresholds
POLICY_ASSESSMENT_THRESHOLD=0.7
WASTE_DENSITY_CRITICAL=300000
WASTE_DENSITY_MODERATE=100000
SORTING_RATE_TARGET=50
URBANIZATION_HIGH=70

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=waste_management_system.log

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5000
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# SECURITY
# ============================================================================

SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_REQUIRED=False
SESSION_TIMEOUT=3600
