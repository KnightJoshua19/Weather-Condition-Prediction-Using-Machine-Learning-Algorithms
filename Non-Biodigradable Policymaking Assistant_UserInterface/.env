# React Frontend Environment Configuration

# API Configuration (Use localhost for local dev, backend for Docker)
# For localhost development:
# REACT_APP_API_URL=http://localhost:5000/api

# For Docker deployment (service name):
REACT_APP_API_URL=http://backend:5000/api

REACT_APP_API_TIMEOUT=30000

# Application Environment
REACT_APP_ENV=development
VITE_PORT=5173

# Feature Flags
REACT_APP_ENABLE_MOCK_API=false
REACT_APP_ENABLE_OFFLINE_MODE=false

# Analytics (Optional)
REACT_APP_ANALYTICS_ID=

# Report Export
REACT_APP_REPORT_FORMAT=json

# UI Configuration
REACT_APP_THEME=light
REACT_APP_SHOW_DEBUG_INFO=true
