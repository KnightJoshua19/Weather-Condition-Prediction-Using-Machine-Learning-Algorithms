# D) DATA PREPROCESSING MODULE
# ============================================================================
class DataPreprocessor:
    """Handles all data cleaning, normalization, and feature engineering"""
    
    def __init__(self, config):
        self.config = config
        self.scaler = MinMaxScaler()
        self.original_df = None
        self.processed_df = None
    
    def load_data(self):
        """Load CSV data"""
        print("[D.1] Loading data...")
        self.original_df = pd.read_csv(self.config.data_path)
        print(f"  ✓ Loaded {len(self.original_df)} records with {len(self.original_df.columns)} columns")
        return self.original_df
    
    def apply_filter(self, series, cutoff=0.1, fs=1.0, order=4):
        """
        Apply low-pass Butterworth filter to smooth noisy numeric data
        Removes high-frequency noise while preserving trends
        """
        if len(series) > order:
            b, a = butter(order, cutoff / (0.5 * fs), btype='low')
            return pd.Series(filtfilt(b, a, series), index=series.index)
        return series
    
    def clean_data(self):
        """
        Data Cleaning Block: Remove noise, fill missing values, deduplicate
        """
        print("[D.2] Cleaning data...")
        df = self.original_df.copy()
        
        # Convert numeric columns to float and apply filtering
        numeric_cols = df.select_dtypes(include='number').columns
        for col in numeric_cols:
            df[col] = df[col].astype(float)
            df[col] = self.apply_filter(
                df[col],
                cutoff=self.config.filter_cutoff,
                order=self.config.filter_order
            )
        
        # Fill missing values with rolling mean (denoising)
        column_mean = df.select_dtypes(include="number").rolling(
            window=self.config.rolling_window,
            center=True
        ).mean()
        df = df.fillna(column_mean)
        df.update(column_mean)
        
        # Remove duplicate rows
        initial_rows = len(df)
        df = df.drop_duplicates()
        removed_rows = initial_rows - len(df)
        print(f"  ✓ Removed {removed_rows} duplicate rows")
        
        self.processed_df = df
        return df
    
    def engineer_features(self):
        """
        Feature Engineering Block: Remove low-variance features
        Keeps only features with meaningful variation
        """
        print("[D.3] Engineering features...")
        df = self.processed_df.copy()
        
        def mean_absolute_difference(series):
            """Calculate MAD - measure of variability"""
            return np.mean(np.abs(series - np.mean(series)))
        
        # Identify and remove low-variance features
        removed_features = []
        numeric_cols = df.select_dtypes(include='number').columns
        for col in numeric_cols:
            mad = mean_absolute_difference(df[col])
            if mad < self.config.variance_threshold:
                removed_features.append(col)
                df.drop(columns=[col], inplace=True)
        
        if removed_features:
            print(f"  ✓ Removed {len(removed_features)} low-variance features: {removed_features[:3]}...")
        
        self.processed_df = df
        return df
    
    def scale_features(self):
        """Normalize numeric features to [0, 1] range for neural network"""
        print("[D.4] Scaling features...")
        df = self.processed_df.copy()
        
        numeric_cols = df.select_dtypes(include='number').columns
        df[numeric_cols] = self.scaler.fit_transform(df[numeric_cols])
        
        self.processed_df = df
        return df
    
    def get_processed_data(self):
        """Execute full preprocessing pipeline"""
        self.load_data()
        self.clean_data()
        self.engineer_features()
        self.scale_features()
        return self.processed_df


