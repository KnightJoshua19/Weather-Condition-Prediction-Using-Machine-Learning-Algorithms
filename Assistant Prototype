def main():
    """Execute the complete waste management analysis pipeline"""
    
    print("\n" + "="*70)
    print("WASTE MANAGEMENT POLICYMAKING ASSISTANT - ML PIPELINE")
    print("="*70 + "\n")
    
    # F.1) Initialize configuration
    config = WasteDataPipelineConfig()
    config.display_config()
    
    # F.2) Data preprocessing
    print("[F.1] DATA PREPROCESSING STAGE")
    print("-" * 70)
    preprocessor = DataPreprocessor(config)
    df = preprocessor.get_processed_data()
    print(f"\nProcessed data shape: {df.shape}")
    print("\nSample of processed data:")
    print(df.head(5).to_string())
    
    # F.3) Prepare features for ML
    print("\n\n[F.2] MODEL PREPARATION STAGE")
    print("-" * 70)
    
    # Select numeric columns for model training
    numeric_df = df.select_dtypes(include='number')
    X = numeric_df.values
    y = (numeric_df.iloc[:, 0] > numeric_df.iloc[:, 0].median()).astype(int).values
    
    X_train, X_test, y_train, y_test = train_test_split(
        X, y,
        test_size=config.test_size,
        random_state=config.random_state
    )
    
    X_train, X_val, y_train, y_val = train_test_split(
        X_train, y_train,
        test_size=0.2,
        random_state=config.random_state
    )
    
    print(f"  Training set: {X_train.shape}")
    print(f"  Validation set: {X_val.shape}")
    print(f"  Test set: {X_test.shape}")
    
    # F.4) Build and train model
    print("\n[F.3] MODEL TRAINING STAGE")
    print("-" * 70)
    
    generator = DataToTextGenerator(config)
    generator.build_keras_model(input_dim=X_train.shape[1])
    history = generator.train_model(X_train, y_train, X_val, y_val)
    
    # F.5) Evaluate model
    print("\n[F.4] MODEL EVALUATION STAGE")
    print("-" * 70)
    
    y_pred = (generator.model.predict(X_test, verbose=0) > 0.5).astype(int).flatten()
    test_accuracy = accuracy_score(y_test, y_pred)
    print(f"  Test Accuracy: {test_accuracy:.4f}")
    
    # F.6) Generate text reports
    print("\n[F.5] DATA-TO-TEXT GENERATION STAGE")
    print("-" * 70)
    
    # Convert back to original feature names and generate reports
    original_X_test = preprocessor.original_df.iloc[df.index[-len(X_test):]].reset_index(drop=True)
    
    print("\nGenerating sample text reports from top 3 records:\n")
    for i in range(min(3, len(original_X_test))):
        row_dict = original_X_test.iloc[i].to_dict()
        text = generator.generate_text(row_dict, mode=config.output_mode)
        print(text)
    
    # F.7) Summary statistics
    print("\n[F.6] SUMMARY STATISTICS")
    print("-" * 70)
    print(f"Total records processed: {len(df)}")
    print(f"Features retained: {df.shape[1]}")
    print(f"Model parameters: {generator.model.count_params():,}")
    print(f"Test accuracy: {test_accuracy:.2%}")
    
    print("\n" + "="*70)
    print("PIPELINE EXECUTION COMPLETED SUCCESSFULLY")
    print("="*70 + "\n")
    
    return {
        'preprocessor': preprocessor,
        'generator': generator,
        'model': generator.model,
        'data': df,
        'test_accuracy': test_accuracy
    }


