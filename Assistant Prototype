import xgboost as xgb
import numpy as np
import pandas as pd

from sklearn.datasets import load_iris
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score
from scipy.signal import butter, filtfilt

getDataFrame = pd.read_csv('C:\\Users\\Joshua\\Waste-Management-Policymaking-Assistant\\public_data_waste_fee.csv')

#A) Data Preprocessing

#Data Cleaning
column_mean = getDataFrame.select_dtypes(include="number").rolling(window=5, center=True).mean() #Get mean and denoising the data
getDataFrame = getDataFrame.fillna(column_mean) #Remove  missing values
getDataFrame.update(column_mean)
def apply_filter(series, cutoff=0.1, fs=1.0, order=4):
    if len(series) > order:
        b, a = butter(order, cutoff / (0.5 * fs), btype='low')
        return pd.Series(filtfilt(b, a, series), index=series.index)
    return series

for col in getDataFrame.select_dtypes(include='number').columns:
    getDataFrame[col] = apply_filter(getDataFrame[col])
getDataFrame = getDataFrame.drop_duplicates() #Remove duplicate rows

getDataFrame.to_csv('C:\\Users\\Joshua\\Waste-Management-Policymaking-Assistant\\public_data_waste_fee.csv', index=False)

