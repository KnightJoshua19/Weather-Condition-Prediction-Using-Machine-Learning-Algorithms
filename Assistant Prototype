# E) DATA-TO-TEXT GENERATION MODULE (Using Keras)
# ============================================================================
class DataToTextGenerator:
    """
    Converts structured waste management data into natural language descriptions
    Uses Keras neural network to learn patterns and generate insights
    """
    
    def __init__(self, config):
        self.config = config
        self.model = None
        self.templates = self._initialize_templates()
    
    def _initialize_templates(self):
        """Initialize text templates for policy generation"""
        templates = {
            'policy': {
                'high_waste': "Region {region} reports HIGH waste density ({wden:.0f} kg/km²). Policy recommendations: Strengthen waste collection infrastructure and implement PAYT systems.",
                'high_urban': "Urban areas in {region} show {urb:.1f}% urbanization. Focus policy on sustainable waste management in dense populations.",
                'sor_alert': "The sorting rate in {region} is {sor:.1f}%, indicating {'room for improvement' if 0 < float('sor', 0) < 50 else 'strong waste segregation'}.",
                'fee_structure': "{region} implements {fee} fee structure with average charge of €{fee_val:.2f}. Effectiveness score: {effectiveness:.1f}%",
            },
            'descriptive': {
                'overview': "{region}, {province} manages {msw:.0f} tons of MSW annually with organic waste comprising {organic:.1f}% of composition.",
                'composition': "Waste composition: Organic {organic:.1f}%, Paper {paper:.1f}%, Glass {glass:.1f}%, Plastic {plastic:.1f}%",
                'infrastructure': "Waste density of {wden:.0f} kg/km² suggests {'robust' if float('wden', 0) > 300000 else 'developing'} waste infrastructure.",
            }
        }
        return templates
    
    def build_keras_model(self, input_dim):
        """
        Build a Keras neural network for feature importance ranking
        Used to identify key waste management insights
        """
        print("[E.1] Building Keras model for data analysis...")
        
        model = models.Sequential([
            layers.Dense(64, activation='relu', input_dim=input_dim, name='input_layer'),
            layers.BatchNormalization(name='batch_norm_1'),
            layers.Dropout(0.3),
            
            layers.Dense(32, activation='relu', name='hidden_layer_1'),
            layers.BatchNormalization(name='batch_norm_2'),
            layers.Dropout(0.2),
            
            layers.Dense(16, activation='relu', name='hidden_layer_2'),
            layers.Dense(1, activation='sigmoid', name='output_layer')
        ], name='WasteManagementPredictor')
        
        model.compile(
            optimizer=optimizers.Adam(learning_rate=0.001),
            loss='binary_crossentropy',
            metrics=['accuracy', 'mse']
        )
        
        print(f"  ✓ Model created with {model.count_params()} parameters")
        self.model = model
        return model
    
    def train_model(self, X_train, y_train, X_val, y_val):
        """Train the Keras model"""
        print("[E.2] Training model...")
        
        history = self.model.fit(
            X_train, y_train,
            validation_data=(X_val, y_val),
            epochs=self.config.epochs,
            batch_size=self.config.batch_size,
            verbose=0
        )
        
        final_acc = history.history['accuracy'][-1]
        print(f"  ✓ Training complete. Final accuracy: {final_acc:.4f}")
        return history
    
    def generate_text(self, data_row, mode='policy'):
        """
        Generate natural language text from data row
        Supports multiple output modes
        """
        region = data_row.get('region', 'Unknown')
        wden = data_row.get('wden', 0)
        urb = data_row.get('urb', 0)
        sor = data_row.get('sor', 0)
        fee = data_row.get('fee', 'STANDARD')
        msw = data_row.get('msw', 0)
        organic = data_row.get('organic', 0)
        paper = data_row.get('paper', 0)
        glass = data_row.get('glass', 0)
        plastic = data_row.get('plastic', 0)
        
        output = f"\n--- Waste Management Report: {region} ---\n"
        output += f"Total MSW: {msw:,.0f} tons/year\n"
        output += f"Waste Density: {wden:,.0f} kg/km²\n"
        output += f"Urban Coverage: {urb:.1f}%\n"
        output += f"Sorting Rate: {sor:.2f}%\n"
        output += f"Fee Type: {fee}\n"
        output += f"\nComposition - Organic: {organic:.1f}%, Paper: {paper:.1f}%, "
        output += f"Glass: {glass:.1f}%, Plastic: {plastic:.1f}%\n"
        
        return output


